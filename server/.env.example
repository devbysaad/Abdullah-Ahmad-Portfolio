NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/abdullah-portfolio
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
ADMIN_PASSWORD=change-me
PORT=3000

# Comma-separated — must include every frontend origin (production + preview)
# Local:
CLIENT_URL=http://localhost:5173
# Vercel production example:
# CLIENT_URL=https://abdullah-ahmad-portfolio-sandy.vercel.app

# Set to false only when testing NODE_ENV=production on http://localhost
# COOKIE_SECURE=false

# Cloudinary (required for admin image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=abdullah-portfolio

# Optional: skip upload on seed if profile already exists in Cloudinary
# CLOUDINARY_PROFILE_URL=https://res.cloudinary.com/your-cloud/image/upload/v123/profile.jpg
