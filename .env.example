# Copy to .env.local for local development

# ── Database (required) ──
# Local: mongodb://127.0.0.1:27017/abdullah-portfolio
# Production: mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/abdullah-portfolio
MONGODB_URI=mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/abdullah-portfolio

# ── App URLs (required) ──
# Local: http://localhost:3000
# Production: https://yourdomain.com (Vercel preview URLs are auto-added)
CLIENT_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Email via Resend (required) ──
# Get your key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx
# Requires verified domain at resend.com/domains (e.g. devnauts.io)
# FROM = label visitors see you got a request (must be @your verified domain)
# TO = your inbox where notifications land
RESEND_FROM_EMAIL=Appointment Request <hello@devnauts.io>
RESEND_TO_EMAIL=abdullah.ahmad@devnauts.io
