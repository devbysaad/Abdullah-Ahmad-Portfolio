# Copy to .env.local for local development

# ── Database (required) ──
MONGODB_URI=mongodb://127.0.0.1:27017/abdullah-portfolio

# ── App URLs (required) ──
# Local: http://localhost:3000
# Production: https://yourdomain.com (Vercel preview URLs are auto-added)
CLIENT_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Email via Resend (required) ──
# Get your key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx
# Requires verified domain at resend.com/domains (e.g. devnauts.io)
RESEND_FROM_EMAIL=Abdullah Ahmad <abdullah.ahmad@devnauts.io>
RESEND_TO_EMAIL=abdullah.ahmad@devnauts.io
