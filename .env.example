# Copy to .env.local for local development

# ── Database (required) ──
MONGODB_URI=mongodb://127.0.0.1:27017/abdullah-portfolio

# ── App URLs (required) ──
# Local: http://localhost:3000
# Production: https://yourdomain.com (Vercel preview URLs are auto-added)
CLIENT_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Email via Resend (required) ──
RESEND_API_KEY=re_xxxxxxxx
# Testing: Portfolio <onboarding@resend.dev> (only sends to your Resend account email)
# Production: Portfolio <hello@yourdomain.com> after verifying domain at resend.com/domains
RESEND_FROM_EMAIL=Portfolio <onboarding@resend.dev>
RESEND_TO_EMAIL=you@example.com
