# Copy to .env.local for local dev (gitignored). On Vercel, add the same keys in Project → Settings → Environment Variables.

# API base URL — must end with /api (no trailing slash after "api")
# Local dev: use /api (Vite proxies to API on 3001). Or full URL: http://localhost:3001/api
VITE_SITE_URL=http://localhost:3000/api

# Public site URL (optional)
# VITE_SITE_URL=http://localhost:3000
