# Local: copy to .env or .env.local (gitignored)
# Vercel: add the same VITE_* keys in Project → Environment Variables

# API — local dev: Vite proxies /api → localhost:3000
VITE_API_URL=/api

# Vercel frontend project — set in dashboard (NOT in local .env):
# VITE_API_URL=https://abdullah-ahmad-portfolio-backend.vercel.app/api
# VITE_SITE_URL=https://abdullah-ahmad-portfolio-sandy.vercel.app
# (/api suffix is required — code auto-appends it if you forget)

# Public site URL (optional locally)
VITE_SITE_URL=http://localhost:5173

# ═══════════════════════════════════════════════════════════════════════════════
# EmailJS — contact message + book-a-call (required for forms to work)
# https://www.emailjs.com/
# ═══════════════════════════════════════════════════════════════════════════════
#
# SETUP (do in order):
#
# 1. Email Services → Add New Service (Gmail/Outlook) → copy Service ID
# 2. Account → API Keys → copy Public Key
# 3. Create TWO templates below (Content → Code editor) → copy each Template ID
# 4. Paste all values here → restart: npm run dev
#
# ─── Your keys ───────────────────────────────────────────────────────────────

VITE_EMAILJS_PUBLIC_KEY=your_public_key
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TO_EMAIL=you@example.com
VITE_EMAILJS_TEMPLATE_MESSAGE=template_message_id
VITE_EMAILJS_TEMPLATE_APPOINTMENT=template_booking_id

# ═══════════════════════════════════════════════════════════════════════════════
# TEMPLATE 1 — "Portfolio Message" (Drop a message form)
# ═══════════════════════════════════════════════════════════════════════════════
#
# Right panel fields:
#   To Email:    {{to_email}}
#   From Name:   {{from_name}}
#   Reply To:    {{reply_to}}
#   Subject:     {{subject}}
#
# Content → Code editor → paste:
#
# <div style="font-family: sans-serif; line-height: 1.6;">
#   <h2>New portfolio message</h2>
#   <p><strong>Name:</strong> {{from_name}}</p>
#   <p><strong>Email:</strong> {{from_email}}</p>
#   <p><strong>Message:</strong></p>
#   <p>{{message}}</p>
# </div>
#
# Variables sent by the app: to_email, from_name, from_email, reply_to, name, email, message, subject
#
# ═══════════════════════════════════════════════════════════════════════════════
# TEMPLATE 2 — "Portfolio Booking" (Book a call form)
# ═══════════════════════════════════════════════════════════════════════════════
#
# Right panel fields (same as above):
#   To Email:    {{to_email}}
#   From Name:   {{from_name}}
#   Reply To:    {{reply_to}}
#   Subject:     {{subject}}
#
# Content → Code editor → paste:
#
# <div style="font-family: sans-serif; line-height: 1.6;">
#   <h2>New call booking request</h2>
#   <p><strong>Name:</strong> {{from_name}}</p>
#   <p><strong>Email:</strong> {{from_email}}</p>
#   <p><strong>When:</strong> {{appointment_summary}}</p>
#   <p><strong>Date:</strong> {{appointment_date}}</p>
#   <p><strong>Time:</strong> {{appointment_time}}</p>
#   <p><strong>Duration:</strong> {{duration}} minutes</p>
#   <p><strong>Timezone:</strong> {{timezone}}</p>
#   <p><strong>Notes:</strong></p>
#   <p>{{message}}</p>
# </div>
#
# Extra variables: appointment_date, appointment_time, appointment_summary, duration, timezone
